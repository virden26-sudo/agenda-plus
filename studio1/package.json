{
  "name": "studio",
  "version": "1.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev -p 9002",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:9002 && electron .\"",
    "electron:start": "concurrently \"npm run start\" \"wait-on http://localhost:9002 && electron .\"",
    "electron:build": "npm run build && npm run electron:start",
    "genkit:dev": "genkit start --tsx src/ai/dev.ts",
    "genkit:watch": "genkit start tsx --watch src/ai/dev.ts",
    "build": "next build",
    "start": "next start -p 9002",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cap:android": "npx cap add android",
    "build:android": "next build && npx cap copy android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@genkit-ai/dotprompt": "^0.9.12",
    "@genkit-ai/google-genai": "^1.0.0",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.1.6",
    "genkit": "^1.29.0",
    "ics": "^3.7.2",
    "lucide-react": "^0.417.0",
    "mammoth": "^1.8.0",
    "next": "15.5.14",
    "next-themes": "^0.3.0",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.1",
    "react": "18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.52.1",
    "react-markdown": "^10.1.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^2.5.0",
    "@types/node": "^20",
    "@types/node-fetch": "^2.6.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "genkit-cli": "^1.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
